#!/usr/bin/env sh
# Gradle Wrapper 启动脚本
# 用法: ./gradlew assembleDebug

# 从环境变量获取 JVM 选项
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# 检查 JAVA_HOME
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

# 检查 java 是否可用
if ! command -v "$JAVACMD" >/dev/null 2>&1; then
    echo "错误: 未找到 Java。请安装 JDK 17 并设置 JAVA_HOME。"
    exit 1
fi

# 脚本所在目录
APP_HOME=$( cd "${0%[/\\]*}" > /dev/null 2>&1 && pwd -P ) || exit
APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}

# 添加默认 JVM 选项
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# 执行 Gradle Wrapper
exec "$JAVACMD" \
    $DEFAULT_JVM_OPTS \
    $JAVA_OPTS \
    $GRADLE_OPTS \
    "-Dorg.gradle.appname=$APP_BASE_NAME" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
